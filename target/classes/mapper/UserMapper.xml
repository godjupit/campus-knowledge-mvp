<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.campus.auth.mapper.UserMapper">
    <insert id="insert">
        insert into users(username, email, password_hash) values(#{username}, #{email}, #{passwordHash});
    </insert>

    <select id="findByUsername" resultType="com.campus.auth.entity.User">
        select * from users where username = #{username};
    </select>

    <select id="findByEmail" resultType="com.campus.auth.entity.User">
        select * from users where email = #{email};
    </select>
    <select id="findById" resultType="com.campus.auth.entity.User">
        select * from users where id = #{id};
    </select>
</mapper>
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.campus.knowledge.mapper.PostMapper">

    <insert id="insertPost">
        insert into posts(title, content, user_id, tags) values(#{title}, #{content}, #{userId}, #{tags});
    </insert>
</mapper>